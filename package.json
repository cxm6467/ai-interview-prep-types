{
  "name": "@cxm6467/ai-interview-prep-types",
  "version": "1.1.1",
  "description": "Comprehensive TypeScript type definitions for AI-powered interview preparation applications",
  "keywords": [
    "typescript",
    "types",
    "interview",
    "resume",
    "ats",
    "ai",
    "job-search",
    "career",
    "interview-prep"
  ],
  "homepage": "https://github.com/cxm6467/ai-interview-prep-types#readme",
  "bugs": {
    "url": "https://github.com/cxm6467/ai-interview-prep-types/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cxm6467/ai-interview-prep-types.git"
  },
  "license": "ISC",
  "author": "Chris Marasco (github.com/cxm6467)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "ci": "npm run build && npm run format:check && npm run spellcheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "spellcheck": "cspell \"src/**/*.{ts,js,md}\" \"*.md\" --no-progress --no-summary",
    "spellcheck:check": "npm run spellcheck",
    "test": "echo \"No tests yet\" && exit 0",
    "docs:validate": "npx tsx scripts/validate-jsdoc.ts",
    "validate:jsdoc": "npx tsx scripts/validate-jsdoc.ts"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "cspell": "^9.2.0",
    "glob": "^11.0.0",
    "husky": "^9.1.7",
    "jest": "^30.1.1",
    "prettier": "^3.6.2",
    "tsx": "^4.19.1",
    "typescript": "^5.9.2"
  }
}
